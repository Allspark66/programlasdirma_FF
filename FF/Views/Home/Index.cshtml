@model List<FF.Models.Product>

@{
    ViewData["Title"] = "Satış Paneli";
}

<!-- Bootstrap Icons və Google Fonts qoşulması -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>
    /* Ümumi Stil */
    body {
        background-color: #f0f2f5;
        font-family: 'Poppins', sans-serif;
    }

    /* Kartın və Başlığın Dizaynı */
    .sales-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        margin-top: 30px;
    }

    .card-header-custom {
        background: linear-gradient(135deg, #004e92, #000428);
        color: white;
        padding: 25px;
        border: none;
    }

    /* Filtr Paneli Stili */
    .filter-section {
        background: #ffffff;
        padding: 20px;
        border-bottom: 1px solid #eee;
    }

    .form-label {
        font-size: 13px;
        color: #6c757d;
        margin-bottom: 5px;
    }

    /* Cədvəl Dizaynı */
    .table-custom {
        background: white;
        margin-bottom: 0;
    }

        .table-custom thead {
            background-color: #f8f9fa;
        }

        .table-custom th {
            border: none;
            color: #495057;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 12px;
            letter-spacing: 1px;
            padding: 20px;
        }

        .table-custom td {
            padding: 20px;
            vertical-align: middle;
            border-top: 1px solid #eee;
        }

        /* Sətir Hover Effekti */
        .table-custom tbody tr {
            transition: all 0.3s ease;
        }

            .table-custom tbody tr:hover {
                background-color: #fdfdfd;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            }

    /* Düymə və İnput Stili */
    .qty-input {
        width: 80px;
        border-radius: 10px;
        border: 1px solid #ddd;
        text-align: center;
        font-weight: 600;
    }

    .btn-sell {
        background: linear-gradient(to right, #11998e, #38ef7d);
        border: none;
        color: white;
        padding: 8px 25px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s;
    }

        .btn-sell:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 15px rgba(17, 153, 142, 0.4);
            color: white;
        }

    /* Redaktə Düyməsi Stili */
    .btn-edit {
        background: linear-gradient(to right, #4facfe, #00f2fe);
        border: none;
        color: white;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        transition: all 0.3s;
        text-decoration: none;
    }

        .btn-edit:hover {
            transform: scale(1.1);
            box-shadow: 0 5px 15px rgba(79, 172, 254, 0.4);
            color: white;
        }

    .badge-custom {
        padding: 8px 12px;
        border-radius: 8px;
        font-size: 11px;
    }

    .pulse-animation {
        animation: pulse-red 2s infinite;
    }

    @@keyframes pulse-red {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.5;
        }

        100% {
            opacity: 1;
        }
    }
</style>

<div class="container pb-5">
    <div class="card sales-card">
        <!-- Başlıq Paneli -->
        <div class="card-header-custom d-flex justify-content-between align-items-center">
            <div>
                <h2 class="mb-0 fw-bold">
                    <i class="bi bi-cart-check me-2"></i> Satış Səhifəsi
                    <a asp-action="History" class="btn btn-sm btn-outline-light ms-3 rounded-pill">Tarixçəyə Bax</a>
                    <a asp-action="ElaveEt" class="btn btn-sm btn-warning ms-2 rounded-pill text-dark fw-bold">+ Yeni Məhsul</a>
                </h2>
            </div>
            <div class="text-end">
                <div class="badge bg-light text-dark p-2">
                    <i class="bi bi-calendar3 me-1"></i> @DateTime.Now.ToString("dd MMMM, yyyy")
                </div>
            </div>
        </div>

        <!-- Filtr və Axtarış Paneli -->
        <div class="filter-section shadow-sm">
            <form id="filterForm" method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-bold"><i class="bi bi-search me-1"></i> Məhsul Axtar</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="search" id="searchInput" class="form-control border-start-0"
                               placeholder="Ad daxil edin..." onkeyup="liveSearch()" value="@Context.Request.Query["search"]">
                    </div>
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-bold">Kateqoriya</label>
                    <select name="category" class="form-select" onchange="this.form.submit()">
                        <option value="" selected="@(Context.Request.Query["category"] == "")">Hamısı</option>
                        <option value="Elektronika" selected="@(Context.Request.Query["category"] == "Elektronika")">Elektronika</option>
                        <option value="Məişət Texnikası" selected="@(Context.Request.Query["category"] == "Məişət Texnikası")">Məişət Texnikası</option>
                        <option value="Aksesuar" selected="@(Context.Request.Query["category"] == "Aksesuar")">Aksesuar</option>
                        <option value="Geyim" selected="@(Context.Request.Query["category"] == "Geyim")">Geyim</option>
                        <option value="Digər" selected="@(Context.Request.Query["category"] == "Digər")">Digər</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-bold">Min. Qiymət</label>
                    <input type="number" name="minPrice" class="form-control" placeholder="0 AZN"
                           onchange="this.form.submit()" value="@Context.Request.Query["minPrice"]">
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold">Sıralama</label>
                    <select name="sort" class="form-select" onchange="this.form.submit()">
                        <option value="" selected="@(Context.Request.Query["sort"] == "")">Standart Sıralama</option>
                        <option value="price_asc" selected="@(Context.Request.Query["sort"] == "price_asc")">Ucuzdan Bahaya</option>
                        <option value="price_desc" selected="@(Context.Request.Query["sort"] == "price_desc")">Bahadan Ucuza</option>
                    </select>
                </div>
            </form>
        </div>

        <!-- Məhsul Cədvəli -->
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-custom">
                    <thead>
                        <tr>
                            <th>Məhsul</th>
                            <th>Qiymət</th>
                            <th>Anbar</th>
                            <th>Satış Miqdarı</th>
                            <th class="text-end" style="padding-right: 40px;">Əməliyyat</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="bg-light p-2 rounded me-3">
                                                <i class="bi bi-box-seam text-primary fs-4"></i>
                                            </div>
                                            <span class="fw-bold text-dark">@item.Name</span>
                                        </div>
                                    </td>
                                    <td><span class="text-success fw-bold">@item.Price.ToString("N2") AZN</span></td>
                                    <td>
                                        @if (item.Stock > 10)
                                        {
                                            <span class="badge bg-success-subtle text-success badge-custom">Stokda var: @item.Stock ədəd</span>
                                        }
                                        else if (item.Stock > 0)
                                        {
                                            <span class="badge bg-warning-subtle text-warning badge-custom pulse-animation">Azalır: @item.Stock ədəd</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger badge-custom">Bitib</span>
                                        }
                                    </td>
                                    <td>
                                        <form asp-action="SatisEt" method="post" id="form_@item.Id">
                                            <input type="hidden" name="productId" value="@item.Id" />
                                            <input type="number" name="quantity" value="1" min="1" max="@item.Stock"
                                                   class="form-control qty-input shadow-sm mx-auto" @(item.Stock == 0 ? "disabled" : "") />
                                        </form>
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2" style="padding-right: 20px;">
                                            <button type="submit" form="form_@item.Id" class="btn btn-sell" @(item.Stock == 0 ? "disabled" : "")>
                                                <i class="bi bi-lightning-fill me-1"></i> Sat
                                            </button>

                                            <a asp-action="RedakteEt" asp-route-id="@item.Id" class="btn btn-edit shadow-sm">
                                                <i class="bi bi-gear-fill"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-search fs-1 d-block mb-2"></i>
                                    Məhsul tapılmadı.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function liveSearch() {
            const input = document.getElementById('searchInput');
            if (input.value.length > 2 || input.value.length === 0) {
                document.getElementById('filterForm').submit();
            }
        }

        @if (!string.IsNullOrEmpty(Context.Request.Query["search"]))
        {
                <text>
                document.getElementById('searchInput').focus();
                let val = document.getElementById('searchInput').value;
                document.getElementById('searchInput').value = '';
                document.getElementById('searchInput').value = val;
                </text>
        }
    </script>
}