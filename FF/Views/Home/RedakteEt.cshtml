@model FF.Models.Product

@{
    ViewData["Title"] = "Məhsul Redaktə Paneli";
}

<!-- Bootstrap Icons və Google Fonts -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>
    body {
        background-color: #f0f2f5;
        font-family: 'Poppins', sans-serif;
    }

    .edit-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        margin-top: 50px;
    }

    .card-header-edit {
        background: linear-gradient(135deg, #004e92, #000428);
        color: white;
        padding: 25px;
        border: none;
    }

    .form-label {
        font-weight: 600;
        color: #495057;
        font-size: 14px;
        margin-top: 10px;
    }

    .form-control, .form-select {
        border-radius: 10px;
        padding: 12px;
        border: 1px solid #dee2e6;
        transition: all 0.3s;
    }

        .form-control:focus {
            box-shadow: 0 0 0 0.25rem rgba(0, 78, 146, 0.1);
            border-color: #004e92;
        }

    .btn-save {
        background: linear-gradient(to right, #11998e, #38ef7d);
        border: none;
        color: white;
        padding: 12px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(17, 153, 142, 0.4);
            color: white;
        }

    .btn-delete {
        background: #ff4b2b;
        background: linear-gradient(to right, #ff416c, #ff4b2b);
        border: none;
        color: white;
        border-radius: 10px;
        padding: 8px 20px;
        font-weight: 600;
        transition: all 0.3s;
    }

        .btn-delete:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 15px rgba(255, 75, 43, 0.3);
            color: white;
        }

    .btn-cancel {
        border-radius: 10px;
        padding: 12px;
        font-weight: 600;
        color: #6c757d;
    }
</style>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card edit-card">
                <!-- Başlıq və Silmə Düyməsi -->
                <div class="card-header-edit d-flex justify-content-between align-items-center">
                    <h4 class="mb-0 fw-bold">
                        <i class="bi bi-pencil-square me-2"></i> Məhsulu Redaktə Et
                    </h4>

                    <form asp-action="Sil" method="post" onsubmit="return confirm('Bu məhsulu bazadan tamamilə silmək istədiyinizə əminsiniz?')">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-delete btn-sm">
                            <i class="bi bi-trash3-fill me-1"></i> Sil
                        </button>
                    </form>
                </div>

                <div class="card-body p-4 bg-white">
                    <form asp-action="RedakteEt" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="row g-3">
                            <!-- Məhsul Adı -->
                            <div class="col-12">
                                <label asp-for="Name" class="form-label">Məhsulun Adı</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-tag text-muted"></i></span>
                                    <input asp-for="Name" class="form-control border-start-0" placeholder="Məs: Laptop" required />
                                </div>
                            </div>

                            <!-- Kateqoriya -->
                            <div class="col-12">
                                <label asp-for="Category" class="form-label">Kateqoriya</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-layers text-muted"></i></span>
                                    <select asp-for="Category" class="form-select border-start-0">
                                        <option value="Elektronika">Elektronika</option>
                                        <option value="Məişət Texnikası">Məişət Texnikası</option>
                                        <option value="Aksesuar">Aksesuar</option>
                                        <option value="Geyim">Geyim</option>
                                        <option value="Digər">Digər</option>
                                    </select>
                                </div>
                            </div>

                            <!-- Qiymət -->
                            <div class="col-md-6">
                                <label asp-for="Price" class="form-label">Qiymət (AZN)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-cash-stack text-muted"></i></span>
                                    <input asp-for="Price" type="number" step="0.01" class="form-control border-start-0" required />
                                </div>
                            </div>

                            <!-- Stok -->
                            <div class="col-md-6">
                                <label asp-for="Stock" class="form-label">Anbar Miqdarı</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-box-seam text-muted"></i></span>
                                    <input asp-for="Stock" type="number" class="form-control border-start-0" required />
                                </div>
                            </div>
                        </div>

                        <!-- Düymələr -->
                        <div class="row mt-5 g-2">
                            <div class="col-md-8">
                                <button type="submit" class="btn btn-save w-100 shadow-sm">
                                    <i class="bi bi-check-circle me-2"></i> Dəyişiklikləri Yadda Saxla
                                </button>
                            </div>
                            <div class="col-md-4">
                                <a asp-action="Index" class="btn btn-outline-secondary btn-cancel w-100">
                                    İmtina
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Kiçik Məlumat Kartı -->
            <div class="mt-4 p-3 bg-primary bg-opacity-10 border border-primary border-opacity-10 rounded-4">
                <p class="small text-primary mb-0">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    Məhsulun adını və ya qiymətini dəyişdikdə bu məlumatlar bütün sistemdə yenilənəcəkdir.
                </p>
            </div>
        </div>
    </div>
</div>